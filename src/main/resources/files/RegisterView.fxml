<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/20.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.csc325_firebase_webview_auth.view.RegisterView"
      spacing="12" alignment="CENTER" prefWidth="420" prefHeight="320">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Register" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <TextField fx:id="emailField" promptText="Email"/>
    <PasswordField fx:id="passwordField" promptText="Password (min 6)"/>

    <Button text="Create Account" onAction="#register"/>
    <Label fx:id="statusLabel"/>

    <Button text="Back" onAction="#goBack"/>
</VBox>
