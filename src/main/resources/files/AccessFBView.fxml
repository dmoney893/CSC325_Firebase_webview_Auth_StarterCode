<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.control.SeparatorMenuItem?>

<AnchorPane prefHeight="571.0" prefWidth="894.0" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.csc325_firebase_webview_auth.view.AccessFBView">
   <children>
        <MenuBar AnchorPane.topAnchor="0.0"
                 AnchorPane.leftAnchor="0.0"
                 AnchorPane.rightAnchor="0.0">
            <menus>

                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem text="Register" onAction="#openRegister"/>
                        <MenuItem text="Sign In" onAction="#openSignIn"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Switch to Web" onAction="#switchToSecondary"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Close" onAction="#closeApp"/>
                    </items>
                </Menu>

                <Menu mnemonicParsing="false" text="Edit">
                    <items>
                        <MenuItem text="Clear Output" onAction="#clearOutput"/>
                        <MenuItem text="Delete Selected" onAction="#deleteSelected"/>
                    </items>
                </Menu>

                <Menu mnemonicParsing="false" text="Help">
                    <items>
                        <MenuItem text="About" onAction="#showAbout"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
       <HBox AnchorPane.topAnchor="28.0"
             AnchorPane.leftAnchor="0.0"
             AnchorPane.rightAnchor="0.0"
             AnchorPane.bottomAnchor="0.0"
             spacing="0"
             styleClass="center-row">
           <children>
             <AnchorPane prefHeight="200.0" prefWidth="200.0" styleClass="left-panel">
                 <children>
                     <ImageView fitHeight="150.0" fitWidth="129.0"
                                layoutX="17.0" layoutY="14.0"
                                pickOnBounds="true" preserveRatio="true">
                         <effect>
                             <InnerShadow>
                                 <color>
                                     <Color red="0.20652228593826294" green="0.1679999977350235" blue="0.6000000238418579" />
                                 </color>
                             </InnerShadow>
                         </effect>
                         <image>
                             <Image url="@profile_empty.png" />
                         </image>
                     </ImageView>
                 </children>
             </AnchorPane>

             <VBox prefHeight="535.0" prefWidth="551.0">
                 <children>
                     <TextArea fx:id="outputField" prefHeight="184.0" prefWidth="514.0" />
                     <TableView prefHeight="351.0" prefWidth="514.0" styleClass="student-table">
                         <columns>
                             <TableColumn prefWidth="75.0" text="C1" />
                             <TableColumn prefWidth="75.0" text="C2" />
                         </columns>
                     </TableView>
                 </children>
             </VBox>

          <VBox prefHeight="535.0" prefWidth="241.0" spacing="10.0" styleClass="right-panel">
          <children>
              <TextField fx:id="nameField" alignment="TOP_LEFT"
                         prefHeight="25.0" prefWidth="272.0"
                         promptText="Name"
                         styleClass="input-field"/>

              <TextField fx:id="majorField"
                         promptText="Major"
                         styleClass="input-field"/>

              <TextField fx:id="ageField"
                         promptText="Age"
                         styleClass="input-field"/>

              <HBox prefHeight="32.0" prefWidth="465.0">
                  <children>
                      <Button fx:id="readButton" mnemonicParsing="false"
                              onAction="#readRecord"
                              prefHeight="25.0" prefWidth="123.0"
                              text="Read" textAlignment="CENTER"
                              styleClass="action-button">
                          <HBox.margin>
                              <Insets left="20.0" right="20.0" />
                          </HBox.margin>
                      </Button>

                      <Button fx:id="writeButton" mnemonicParsing="false"
                              onAction="#addRecord"
                              prefHeight="25.0" prefWidth="128.0"
                              text="Write" textAlignment="CENTER"
                              styleClass="action-button">
                          <HBox.margin>
                              <Insets left="20.0" right="20.0" />
                          </HBox.margin>
                      </Button>
                  </children>
              </HBox>
            <AnchorPane prefHeight="200.0" prefWidth="200.0">
               <children>
                  <ImageView fitHeight="150.0" fitWidth="129.0" layoutX="17.0" layoutY="14.0" pickOnBounds="true" preserveRatio="true">
                     <effect>
                        <InnerShadow>
                           <color>
                              <Color red="0.20652228593826294" green="0.1679999977350235" blue="0.6000000238418579" />
                           </color>
                        </InnerShadow>
                     </effect>
                     <image>
                        <Image url="@profile_empty.png" />
                     </image>
                  </ImageView>
               </children>
            </AnchorPane>
                      <Button fx:id="switchroot" mnemonicParsing="false"
                              onAction="#switchToSecondary"
                              prefHeight="25.0" prefWidth="283.0"
                              text="Switch" textAlignment="CENTER"
                              styleClass="action-button" />
                  </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </children>
      </HBox>
   </children>
   <opaqueInsets>
      <Insets />
   </opaqueInsets>
</AnchorPane>
